{
  "manifest_version": 3,
  "name": "BlackRoad Command Center",
  "version": "1.1.0",
  "description": "Fleet monitoring, service access, and quick navigation for BlackRoad OS infrastructure",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "BlackRoad Command Center"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["alarms", "storage"]
}
